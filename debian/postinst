#!/bin/sh
# postinst script for eat-my-sms
#
# see: dh_installdeb(1)

set -e

# summary of how this script can be called:
#        * <postinst> `configure' <most-recently-configured-version>
#        * <old-postinst> `abort-upgrade' <new version>
#        * <conflictor's-postinst> `abort-remove' `in-favour' <package>
#          <new-version>
#        * <postinst> `abort-remove'
#        * <deconfigured's-postinst> `abort-deconfigure' `in-favour'
#          <failed-install-package> <version> `removing'
#          <conflicting-package> <version>
# for details, see https://www.debian.org/doc/debian-policy/ or
# the debian-policy package


case "$1" in
    configure)
    ;;

    abort-upgrade|abort-remove|abort-deconfigure)
    ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

# Reload systemd to make service available
if [ -d /run/systemd/system ]; then
    systemctl --system daemon-reload >/dev/null || true
fi

# Create TLS client CA and cert (when not already available)
TLS_DIR=/etc/eat-my-sms/tls
if [ ! -e $TLS_DIR ]; then
    mkdir $TLS_DIR
    openssl req -x509 -sha256 -newkey rsa:4096 -keyout $TLS_DIR/ca.key -out $TLS_DIR/ca.crt -days 365 -nodes -subj '/CN=eat-my-sms CA'
    openssl req -new -newkey rsa:4096 -keyout $TLS_DIR/tls.key -out $TLS_DIR/tls.csr -nodes -subj '/CN=eat-my-sms'
    openssl x509 -req -sha256 -days 365 -in $TLS_DIR/tls.csr -CA $TLS_DIR/ca.crt -CAkey $TLS_DIR/ca.key -set_serial 02 -out $TLS_DIR/tls.crt
    chown -R pushprox:pushprox $TLS_DIR
fi

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0
